<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xmlns:apps="http://schemas.google.com/apps/2006">
  <title>Gmail Filters - FINAL STRUCTURE (SI, 2025) - NO AI</title>
  <author><name>Rok Kambič</name><email>rok.kambic@gmail.com</email></author>
  <updated>2025-11-16T00:26:00Z</updated>

  <!-- ============================================= -->
  <!-- 1. FINANCE LABELS -->
  <!-- ============================================= -->

  <!-- 1.1 Bank Alerts (SI + Global) -->
  <entry>
    <category term="filter"/>
    <title>Finance/Bank - SI Banks</title>
    <id>tag:mail.google.com,2008:filter:finance-bank-si</id>
    <content/>
    <apps:property name="from" value="nlb.si OR lon.si OR mbank.si OR skrill.com OR paypal.com OR stripe.com"/>
    <apps:property name="hasTheWord" value="račun OR plačilo OR transakcija OR kartica OR payment OR transaction"/>
    <apps:property name="label" value="Finance/Bank"/>
    <apps:property name="shouldStar" value="true"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- 1.2 Receipts & Invoices -->
  <entry>
    <category term="filter"/>
    <title>Finance/Receipts</title>
    <id>tag:mail.google.com,2008:filter:finance-receipts</id>
    <content/>
    <apps:property name="hasTheWord" value="receipt OR račun OR invoice OR order confirmation OR potrdilo"/>
    <apps:property name="hasAttachment" value="true"/>
    <apps:property name="label" value="Finance/Receipts"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- 1.3 Crypto Spam → Trash -->
  <entry>
    <category term="filter"/>
    <title>Finance/Crypto → Trash</title>
    <id>tag:mail.google.com,2008:filter:finance-crypto-trash</id>
    <content/>
    <apps:property name="hasTheWord" value="airdrop OR whitelist OR mint OR NFT OR crypto OR bitcoin OR free money"/>
    <apps:property name="label" value="Finance/Crypto"/>
    <apps:property name="shouldTrash" value="true"/>
  </entry>

  <!-- ============================================= -->
  <!-- 2. SHOPPING LABELS -->
  <!-- ============================================= -->

  <!-- 2.1 Orders -->
  <entry>
    <category term="filter"/>
    <title>Shopping/Orders</title>
    <id>tag:mail.google.com,2008:filter:shopping-orders</id>
    <content/>
    <apps:property name="from" value="mimovrste.com OR amazon.com OR aliexpress.com OR zalando.si"/>
    <apps:property name="hasTheWord" value="naročilo OR order OR potrditev"/>
    <apps:property name="label" value="Shopping/Orders"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- 2.2 Delivery & Tracking -->
  <entry>
    <category term="filter"/>
    <title>Shopping/Delivery</title>
    <id>tag:mail.google.com,2008:filter:shopping-delivery</id>
    <content/>
    <apps:property name="from" value="dpd.si OR gls.si OR posta.si OR dhl.com"/>
    <apps:property name="hasTheWord" value="pošiljka OR paket OR dostava OR tracking OR shipment"/>
    <apps:property name="label" value="Shopping/Delivery"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- ============================================= -->
  <!-- 3. WORK LABELS -->
  <!-- ============================================= -->

  <!-- 3.1 GitHub -->
  <entry>
    <category term="filter"/>
    <title>Work/GitHub</title>
    <id>tag:mail.google.com,2008:filter:work-github</id>
    <content/>
    <apps:property name="from" value="notifications@github.com"/>
    <apps:property name="hasTheWord" value="pull request OR issue OR commit"/>
    <apps:property name="label" value="Work/GitHub"/>
    <apps:property name="shouldStar" value="true"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- 3.2 Jira / Confluence -->
  <entry>
    <category term="filter"/>
    <title>Work/Jira</title>
    <id>tag:mail.google.com,2008:filter:work-jira</id>
    <content/>
    <apps:property name="from" value="atlassian.net"/>
    <apps:property name="hasTheWord" value="JIRA OR ticket OR sprint"/>
    <apps:property name="label" value="Work/Jira"/>
    <apps:property name="shouldStar" value="true"/>
  </entry>

  <!-- 3.3 Meetings -->
  <entry>
    <category term="filter"/>
    <title>Work/Meetings</title>
    <id>tag:mail.google.com,2008:filter:work-meetings</id>
    <content/>
    <apps:property name="hasTheWord" value="zoom.us/j/ OR meet.google.com OR teams.microsoft.com OR sestanek OR meeting"/>
    <apps:property name="label" value="Work/Meetings"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- ============================================= -->
  <!-- 4. TRAVEL -->
  <!-- ============================================= -->

  <entry>
    <category term="filter"/>
    <title>Travel</title>
    <id>tag:mail.google.com,2008:filter:travel</id>
    <content/>
    <apps:property name="from" value="ryanair.com OR flixbus.com OR booking.com OR airbnb.com OR slovenske-zeleznice.si"/>
    <apps:property name="hasTheWord" value="letalska OR vlak OR avtobus OR hotel OR visa OR boarding"/>
    <apps:property name="label" value="Travel"/>
    <apps:property name="shouldStar" value="true"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- ============================================= -->
  <!-- 5. NEWSLETTERS -->
  <!-- ============================================= -->

  <entry>
    <category term="filter"/>
    <title>Newsletters</title>
    <id>tag:mail.google.com,2008:filter:newsletters</id>
    <content/>
    <apps:property name="hasTheWord" value="newsletter OR posodobitev OR tedenski OR monthly OR unsubscribe OR odjava"/>
    <apps:property name="label" value="Newsletters"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- ============================================= -->
  <!-- 6. SPAM & TRASH -->
  <!-- ============================================= -->

  <!-- 6.1 Jackpot / Winner Spam -->
  <entry>
    <category term="filter"/>
    <title>Spam: Jackpot/Winner</title>
    <id>tag:mail.google.com,2008:filter:spam-jackpot</id>
    <content/>
    <apps:property name="hasTheWord" value="jackpot OR milijon OR winner OR dobitnik"/>
    <apps:property name="shouldTrash" value="true"/>
  </entry>

  <!-- 6.2 Promotions Tab → Trash -->
  <entry>
    <category term="filter"/>
    <title>Trash: Promotions Tab</title>
    <id>tag:mail.google.com,2008:filter:trash-promotions</id>
    <content/>
    <apps:property name="hasTheWord" value="category:promotions"/>
    <apps:property name="shouldTrash" value="true"/>
  </entry>

  <!-- ============================================= -->
  <!-- 7. AUTO-ARCHIVE NON-IMPORTANT -->
  <!-- ============================================= -->

  <entry>
    <category term="filter"/>
    <title>Auto-Archive: Everything Else</title>
    <id>tag:mail.google.com,2008:filter:archive-all</id>
    <content/>
    <apps:property name="query" value="-in:starred -label:Finance -label:Work -label:Shopping -label:Travel -is:unread"/>
    <apps:property name="shouldArchive" value="true"/>
  </entry>

  <!-- ============================================= -->
  <!-- 8. STAR ALL ATTACHMENTS -->
  <!-- ============================================= -->

  <entry>
    <category term="filter"/>
    <title>Star: All Attachments</title>
    <id>tag:mail.google.com,2008:filter:star-attachments</id>
    <content/>
    <apps:property name="hasAttachment" value="true"/>
    <apps:property name="shouldStar" value="true"/>
  </entry>

</feed>
