    <!-- Trash filters by subject/word -->
    <entry>
        <category term='filter'/>
        <title>Mail Filter</title>
        <id>tag:mail.google.com,2008:filter:subject_trash</id>
        <content></content>
        <apps:property name='subject' value='Novo narocilo kartice s spletne strani'/>
        <apps:property name='subject' value='JACKPOT'/>
        <apps:property name='hasTheWord' value='MiIIion'/>
        <apps:property name='hasTheWord' value='winner'/>
        <apps:property name='hasTheWord' value='category:promotions'/>
        <apps:property name='shouldTrash' value='true'/>
    </entry>

    <!-- Starred with attachment -->
    <entry>
        <category term='filter'/>
        <title>Mail Filter</title>
        <id>tag:mail.google.com,2008:filter:star_attachment</id>
        <content></content>
        <apps:property name='hasAttachment' value='true'/>
        <apps:property name='shouldStar' value='true'/>
    </entry>

